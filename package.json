{
  "name": "tramado",
  "description": "Tramado - Pattern Studio, software de diseño textil",
  "repository": {
    "type": "git",
    "url": "https://github.com/patocampos20/tramado.git"
  },
  "author": {
    "name": "Patricio Campos",
    "email": "contacto@tramado.app"
  },
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite --port 5173\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "electron:build": "npm run build && electron-builder --win --linux"
  },
  "build": {
    "appId": "com.tramado.app",
    "publish": [
      {
        "provider": "github",
        "owner": "patocampos20",
        "repo": "tramado"
      }
    ],
    "productName": "Tramado",
    "copyright": "Copyright © 2026 Carolina Campos",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "icon": "public/favicon.svg"
    },
    "win": {
      "target": "portable",
      "icon": "public/favicon.svg"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/favicon.svg",
      "category": "Graphics",
      "desktopName": "tramado.desktop",
      "syncDesktopName": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "immer": "^11.1.8",
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "uuid": "^14.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
